# Database Configuration
DB_NAME=pdf_library
DB_USER=dev
DB_PASSWORD=devpass
DATABASE_URL=postgresql://dev:devpass@postgres:5432/pdf_library

# Redis Configuration
REDIS_URL=redis://redis:6379

# API Configuration
SECRET_KEY=your-secret-key-change-this-in-production
API_PORT=8000
API_URL=http://localhost:8000/api/v1

# Frontend Configuration
REACT_APP_API_URL=http://localhost:8000/api/v1
REACT_APP_DEBUG=true
WEB_PORT=3000

# OCR Configuration
OCR_LANGUAGE=eng
TESSERACT_PATH=/usr/bin/tesseract
PADDLEOCR_USE_GPU=false
OCR_CONFIDENCE_THRESHOLD=0.7
OCR_MAX_WORKERS=3

# Metadata Lookup Configuration
GOOGLE_BOOKS_API_KEY=your-google-books-api-key
OPENLIB_API_URL=https://openlibrary.org
METADATA_CONFIDENCE_THRESHOLD=0.9

# Celery Configuration
CELERY_BROKER_URL=redis://redis:6379
CELERY_RESULT_BACKEND=redis://redis:6379
CELERY_CONCURRENCY=4

# Logging Configuration
LOG_LEVEL=DEBUG
LOG_FORMAT=json

# File Storage
LIBRARY_ROOT_PATH=/library
NAMING_TEMPLATE={Publisher}/{Game}/{Game Name} {Title} - {ISBN} - {Publication Date}
MAX_UPLOAD_SIZE=500000000  # 500MB

# GitHub (for Docker images)
GITHUB_USERNAME=jbowensii
IMAGE_TAG=latest

# Unraid Production Configuration (override these)
# DB_USER=your_secure_username
# DB_PASSWORD=your_secure_password
# SECRET_KEY=your_production_secret_key
# GOOGLE_BOOKS_API_KEY=your_api_key
