# Copy to .env next to the compose file and fill in real values.

# PostgreSQL
DB_USER=pdf_user
DB_PASSWORD=CHANGE_ME            # e.g. openssl rand -base64 24
DB_NAME=pdf_library

# Backend JWT signing key
SECRET_KEY=CHANGE_ME             # e.g. openssl rand -hex 32

# Host ports
WEB_PORT=3000
API_PORT=8000
